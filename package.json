{
  "name": "scribattle",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "typecheck:server": "tsc -p server",
    "stdb:publish": "spacetime publish scribattle --module-path server",
    "stdb:publish:cloud": "spacetime publish scribattle --server maincloud --module-path server",
    "stdb:publish:cloud:reset": "spacetime publish scribattle --server maincloud --module-path server --delete-data",
    "stdb:logs:cloud": "spacetime logs scribattle --server maincloud",
    "stdb:generate": "spacetime generate --lang typescript --out-dir app/spacetime/module_bindings --module-path server",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@clerk/react-router": "^3.5.4",
    "@libsql/client": "^0.17.4",
    "@react-router/node": "^7.14.0",
    "@react-router/serve": "^7.14.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "drizzle-orm": "^0.45.2",
    "isbot": "^5.1.36",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.14.0",
    "spacetimedb": "^2.6.1",
    "three": "^0.185.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@react-router/dev": "^7.14.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.6"
  }
}
