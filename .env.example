# Clerk (https://dashboard.clerk.com → API Keys)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Turso — staging/dev (default target for db:push, db:migrate, db:studio)
TURSO_DATABASE_URL=libsql://scribattle-YOURORG.turso.io
TURSO_AUTH_TOKEN=

# Turso — production (target for db:*:prod scripts). Keep this separate from staging.
TURSO_PROD_DATABASE_URL=libsql://scribattle-production-YOURORG.turso.io
TURSO_PROD_AUTH_TOKEN=

# SpacetimeDB
#   Maincloud (remote): https://maincloud.spacetimedb.com
#   Local (spacetime start): http://localhost:3000
VITE_SPACETIMEDB_URI=https://maincloud.spacetimedb.com
VITE_SPACETIMEDB_NAME=scribattle
